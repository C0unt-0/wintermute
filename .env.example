# Wintermute hybrid dev environment
# Copy to .env and adjust values for local dev:
#   cp .env.example .env

# Database (Dockerized PostgreSQL with pgvector)
WINTERMUTE_DATABASE_URL=postgresql+psycopg://wintermute:wintermute_dev@localhost:5432/wintermute

# Redis (Dockerized)
REDIS_URL=redis://localhost:6379/0

# Docker Compose
DB_PASSWORD=wintermute_dev
